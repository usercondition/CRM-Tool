# Copy to .env for local development (optional)

# Persistent storage — leave unset to use data/store.json locally.
# On Render: create a PostgreSQL database and link it to the web service (DATABASE_URL is set automatically).
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Protect the CRM when hosted online (required for production).
# CRM_PASSWORD=choose-a-strong-password

# Optional separate signing secret for session cookies (defaults to CRM_PASSWORD).
# CRM_SESSION_SECRET=long-random-string

# Daily digest recipient (preview always works; email needs SMTP below).
# CRM_DIGEST_EMAIL=you@example.com

# SMTP for sending digest emails (optional).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@example.com
# SMTP_PASS=app-password
# SMTP_FROM=CRM <you@example.com>

# Orders with no activity for this many days are flagged as stale (default 7).
# STALE_ORDER_DAYS=7

# PORT=3847
