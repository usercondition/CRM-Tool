# Copy to .env for local development (optional)

# Persistent storage — leave unset to use data/store.json locally.
# On Render: create a PostgreSQL database and link it to the web service (DATABASE_URL is set automatically).
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Protect the CRM when hosted online (required for production).
# CRM_PASSWORD=choose-a-strong-password

# Optional separate signing secret for session cookies (defaults to CRM_PASSWORD).
# CRM_SESSION_SECRET=long-random-string

# PORT=3847
